{
  "name": "oh-my-copilot",
  "version": "1.1.0",
  "description": "Terminal AI coding agent powered by GitHub Copilot. No API key needed.",
  "license": "MIT",
  "author": "JJongyn",
  "bin": {
    "oh-my-copilot": "./src/bin/oh-my-copilot.mjs",
    "omc": "./src/bin/oh-my-copilot.mjs"
  },
  "scripts": {
    "postinstall": "cd ~ && node \"$npm_config_prefix/lib/node_modules/$npm_package_name/scripts/install-bridge.js\" || true",
    "verify": "npm --prefix src run typecheck && npm --prefix src run build && npm --prefix src test && npm --prefix bridge run compile",
    "package:bridge": "npm --prefix bridge run compile && (cd bridge && npx vsce package --no-dependencies)"
  },
  "files": [
    "README.md",
    "LICENSE",
    "docs/CHANGELOG.md",
    "docs/RELEASE.md",
    "docs/assets/preview.png",
    "scripts/install-bridge.js",
    "scripts/setup.sh",
    "src/bin/",
    "src/dist/",
    "bridge/*.vsix"
  ],
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.5.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "eventsource-parser": "^3.0.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "jsonc-parser": "^3.3.1",
    "marked": "^12.0.0",
    "marked-terminal": "^7.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.77.0",
    "ora": "^8.1.1",
    "react": "^19.2.4",
    "readline": "^1.3.0",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["ai", "agent", "copilot", "terminal", "cli", "github-copilot"],
  "repository": {
    "type": "git",
    "url": "https://github.com/JJongyn/oh-my-copilot.git"
  },
  "bugs": {
    "url": "https://github.com/JJongyn/oh-my-copilot/issues"
  },
  "homepage": "https://github.com/JJongyn/oh-my-copilot#readme"
}
