{
  "name": "oh-my-copilot",
  "version": "1.1.0",
  "description": "A CLI tool for VSCode Copilot Chat — oh-my-openagent style, powered by vscode.lm",
  "bin": {
    "oh-my-copilot": "./bin/oh-my-copilot.mjs",
    "omc": "./bin/oh-my-copilot.mjs"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "node build.mjs",
    "start": "node bin/oh-my-copilot.js",
    "test": "bun test",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.5.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "eventsource-parser": "^3.0.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "jsonc-parser": "^3.3.1",
    "marked": "^12.0.0",
    "marked-terminal": "^7.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.77.0",
    "ora": "^8.1.1",
    "react": "^19.2.4",
    "readline": "^1.3.0",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "esbuild": "^0.27.4",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
